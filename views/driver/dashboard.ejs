<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Dashboard</title>
    <link href="/css/style.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-100 font-['Roboto',_sans-serif]">
    <nav class="bg-white shadow-md">
        <div class="container mx-auto px-6 py-3 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold text-blue-600">Where is my Bus? 🚌</a>
            <div>
                <a href="/" class="text-gray-700 hover:text-blue-600 font-medium px-3 py-2">View Routes</a>
                <form action="/auth/logout" method="POST" class="inline">
                    <button type="submit" class="text-gray-700 hover:text-blue-600 font-medium px-3 py-2">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <main class="container mx-auto p-4 md:p-6">
        <h1 class="text-3xl font-bold text-gray-800 mb-6">Driver Dashboard</h1>

        <% if (bus) { %>
            <div class="bg-white p-6 rounded-xl shadow-lg">
                <div class="flex flex-col md:flex-row justify-between md:items-center border-b border-gray-200 pb-4 mb-4">
                    <div>
                        <h2 class="text-2xl font-bold text-gray-800"><%= bus.routeName %></h2>
                        <p class="text-gray-500">Bus Number: <span class="font-medium text-gray-700"><%= bus.busNumber %></span></p>
                    </div>
                    <a href="/dashboard/bus/edit" class="mt-4 md:mt-0 inline-block bg-gray-200 text-gray-800 font-semibold px-5 py-2 rounded-lg hover:bg-gray-300 transition-colors">
                        Edit Bus & Route
                    </a>
                </div>

                <div class="mt-6">
                    <h3 class="text-lg font-bold text-gray-700 mb-3">Live Tracking Controls</h3>
                    <div id="status" class="mb-4 p-4 bg-gray-50 border border-gray-200 rounded-lg text-gray-600">
                        Status: Waiting for action...
                    </div>
                    <div class="flex flex-wrap gap-4">
                        <button id="start-tracking" class="flex-1 bg-green-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-600 transition-transform active:scale-95 disabled:bg-gray-400 disabled:cursor-not-allowed">
                            START LIVE TRACKING
                        </button>
                        <button id="stop-tracking" class="flex-1 bg-red-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-red-600 transition-transform active:scale-95 disabled:bg-gray-400 disabled:cursor-not-allowed" disabled>
                            STOP LIVE TRACKING
                        </button>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="bg-white p-8 rounded-xl shadow-lg text-center">
                <h2 class="text-2xl font-bold text-gray-800">Welcome, Driver!</h2>
                <p class="text-gray-500 mt-2 mb-6">You haven't set up your bus yet. Add your bus and route details to start tracking.</p>
                <a href="/dashboard/bus/edit" class="bg-blue-600 text-white font-bold px-8 py-3 rounded-lg hover:bg-blue-700 transition-colors">
                    Add Bus Details
                </a>
            </div>
        <% } %>
    </main>
    
    <script>
        const busId = "<%= bus ? bus._id : '' %>";
    </script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/driver.js"></script>
</body>
</html>